{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":gitSignOff",
    "config:best-practices"
  ],
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "minimumReleaseAge": "7 days",
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "minimumReleaseAge": "1 day"
  },
  "packageRules": [
    {
      "description": "Bump Python dependency ranges",
      "matchManagers": ["pep621", "pip_requirements", "pip-compile"],
      "rangeStrategy": "bump"
    },
    {
      "description": "Disable Python version updates everywhere (pinned to 3.12)",
      "matchDepNames": ["python"],
      "enabled": false
    },
    {
      "description": "Batch and auto-merge safe non-major dependency updates",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "all non-major dependencies",
      "groupSlug": "all-non-major",
      "automerge": true,
      "automergeType": "pr"
    }
  ]
}
